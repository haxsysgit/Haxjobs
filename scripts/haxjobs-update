#!/usr/bin/env bash
# Update the Archilles HaxJobs checkout from GitHub and restart local services.
#
# Usage:
#   haxjobs-update
#   haxjobs-update --no-restart
#   HAXJOBS_REF=feature-branch haxjobs-update

set -euo pipefail

REPO_URL="${HAXJOBS_REPO_URL:-https://github.com/haxsysgit/Haxjobs.git}"
REF="${HAXJOBS_REF:-main}"
APP_DIR="${HAXJOBS_DIR:-/home/hermes/haxjobs}"
NO_RESTART="false"

if [[ "${1:-}" == "--no-restart" ]]; then
  NO_RESTART="true"
fi

log() {
  printf '[haxjobs-update] %s\n' "$*"
}

preserve_runtime_dirs() {
  local backup_dir="$1"
  mkdir -p "$backup_dir"

  for item in intake packs state reports outreach .venv; do
    if [[ -e "$APP_DIR/$item" ]]; then
      log "Preserving runtime item: $item"
      mv "$APP_DIR/$item" "$backup_dir/$item"
    fi
  done
}

restore_runtime_dirs() {
  local backup_dir="$1"

  for item in intake packs state reports outreach .venv; do
    if [[ -e "$backup_dir/$item" ]]; then
      log "Restoring runtime item: $item"
      rm -rf "$APP_DIR/$item"
      mv "$backup_dir/$item" "$APP_DIR/$item"
    fi
  done
}

bootstrap_checkout_if_needed() {
  if [[ -d "$APP_DIR/.git" ]]; then
    return
  fi

  log "No git checkout found at $APP_DIR. Bootstrapping from GitHub."
  local parent backup tmp
  parent="$(dirname "$APP_DIR")"
  backup="$parent/haxjobs.runtime.$(date +%Y%m%d_%H%M%S)"
  tmp="$parent/haxjobs.clone.$(date +%Y%m%d_%H%M%S)"

  if [[ -d "$APP_DIR" ]]; then
    preserve_runtime_dirs "$backup"
    mv "$APP_DIR" "$backup/source_before_git"
  fi

  git clone "$REPO_URL" "$tmp"
  mv "$tmp" "$APP_DIR"
  restore_runtime_dirs "$backup"
}

restart_services() {
  if [[ "$NO_RESTART" == "true" ]]; then
    log "Skipping restarts because --no-restart was passed."
    return
  fi

  if [[ -x "$APP_DIR/dashctl.sh" ]]; then
    log "Restarting dashboard/API via dashctl.sh"
    bash "$APP_DIR/dashctl.sh" restart || log "dashctl restart failed, continuing"
  fi

  if pgrep -f "vite.*5173" >/dev/null 2>&1; then
    log "Restarting Vite dev server"
    pkill -f "vite.*5173" || true
  fi

  if [[ -d "$APP_DIR/dashboard" ]]; then
    log "Starting Vite dev server on 5173"
    nohup bash -lc "cd '$APP_DIR/dashboard' && exec npx vite --port 5173 --host 127.0.0.1" \
      > /tmp/haxjobs-vite.log 2>&1 < /dev/null &
  fi
}

main() {
  bootstrap_checkout_if_needed

  cd "$APP_DIR"
  log "Fetching $REF from $REPO_URL"
  git remote set-url origin "$REPO_URL" 2>/dev/null || git remote add origin "$REPO_URL"
  git fetch origin "$REF" --prune

  log "Resetting checkout to origin/$REF"
  git checkout "$REF" 2>/dev/null || git checkout -B "$REF" "origin/$REF"
  git reset --hard "origin/$REF"

  log "Installing dashboard dependencies if needed"
  if [[ -f dashboard/package-lock.json ]]; then
    (cd dashboard && npm ci --silent)
  elif [[ -f dashboard/package.json ]]; then
    (cd dashboard && npm install --silent)
  fi

  restart_services

  log "Done. Current HEAD: $(git rev-parse --short HEAD)"
}

main "$@"
