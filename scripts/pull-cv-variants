#!/usr/bin/env bash
# Pull reusable CV variants (PDFs, HTML, registry) from Archilles to a local dir.
# Default local target is ~/haxjobs/cv_variants unless overridden.
# Remote source defaults to Archilles' standard HaxJobs location.

set -euo pipefail

LOCAL_ROOT="${1:-$HOME/haxjobs/cv_variants}"
REMOTE_ROOT="archilles:${HAXJOBS_REMOTE_HOME:?Set HAXJOBS_REMOTE_HOME to the remote HaxJobs path}/cv_variants/"

mkdir -p "$LOCAL_ROOT"

echo "Pulling reusable CV variants from Archilles..."
echo "Remote: $REMOTE_ROOT"
echo "Local:  $LOCAL_ROOT/"

rsync -avz --progress \
  --exclude 'registry.py' \
  --exclude '__pycache__/' \
  "$REMOTE_ROOT" "$LOCAL_ROOT/"

echo "Done. Local CV variant files:"
find "$LOCAL_ROOT" -maxdepth 2 -type f \
  \( -iname '*.pdf' -o -iname '*.html' -o -iname 'registry.json' \) \
  -printf '%p\n' | sort
