#!/usr/bin/env bash
# Hermes WebUI SSH tunnel to Archilles.
# Forwards Archilles WebUI (8788) to localhost.
# Usage: archilles-webui
set -euo pipefail

LOCAL_PORT="${ARCHILLES_WEBUI_PORT:-8788}"
REMOTE_USER="hermes"
REMOTE_HOST="178.105.245.120"
REMOTE_PORT="2222"
KEY="$HOME/.ssh/hermes-agent"

echo "Opening Archilles WebUI tunnel..."
echo "  http://localhost:$LOCAL_PORT"
echo "  Password: archilles"
echo "  (Ctrl+C to close)"

exec ssh -i "$KEY" -p "$REMOTE_PORT" \
  -L "${LOCAL_PORT}:127.0.0.1:8788" \
  -N -o ServerAliveInterval=60 \
  "${REMOTE_USER}@${REMOTE_HOST}"
