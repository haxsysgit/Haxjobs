#!/usr/bin/env bash
# HaxJobs dev helper — wraps haxjobs dev commands with project defaults.
# Usage: ./dev [restart|reset|status|build|start]

set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
CMD="${1:-restart}"

cd "$ROOT"

case "$CMD" in
  restart)
    echo "==> rebuild frontend"
    cd "$ROOT/frontend" && npm run build -- --logLevel warn 2>&1 | tail -1
    cd "$ROOT"
    echo "==> restart server"
    PYTHONPATH=src:. "$ROOT/.venv/bin/haxjobs" dev restart --project-root "$ROOT"
    ;;
  reset)
    PYTHONPATH=src:. "$ROOT/.venv/bin/haxjobs" dev reset
    ;;
  status)
    PYTHONPATH=src:. "$ROOT/.venv/bin/haxjobs" dev status
    ;;
  build)
    echo "==> rebuild frontend"
    cd "$ROOT/frontend" && npm run build -- --logLevel warn
    cd "$ROOT"
    echo "==> compile Python"
    PYTHONPATH=src:. .venv/bin/python -m py_compile $(find src -name '*.py') 2>&1 || true
    echo "done"
    ;;
  start)
    echo "==> rebuild frontend"
    cd "$ROOT/frontend" && npm run build -- --logLevel warn 2>&1 | tail -1
    cd "$ROOT"
    echo "==> start server"
    PYTHONPATH=src:. "$ROOT/.venv/bin/python" -m haxjobs.server.main --no-browser
    ;;
  test)
    echo "==> tests"
    PYTHONPATH=src:. "$ROOT/.venv/bin/python" -m pytest -q tests/
    ;;
  *)
    echo "Usage: ./dev [restart|reset|status|build|start|test]"
    exit 1
    ;;
esac
