#!/usr/bin/env python3
"""Render one or all CV variants from source markdown to HTML and PDF.

Usage:
  python3 scripts/render-cv-variant backend_python
  python3 scripts/render-cv-variant --all

The output filenames come from cv_variants/registry.json. Do not invent names.
"""

from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT))

from cv_variants.renderer import render_html, render_pdf  # noqa: E402

REGISTRY_PATH = ROOT / "cv_variants" / "registry.json"


def load_registry() -> dict:
    """Load the reusable CV variant registry."""
    return json.loads(REGISTRY_PATH.read_text())


def render_variant(variant_id: str, registry: dict) -> None:
    """Render a single variant using registry-defined source and output names."""
    variants = registry["variants"]
    if variant_id not in variants:
        valid = ", ".join(sorted(variants))
        print(f"ERROR: unknown variant '{variant_id}'. Valid variants: {valid}")
        raise SystemExit(1)

    variant = variants[variant_id]
    source = ROOT / variant.get("source_md", f"cv_variants/{variant_id}/cv_source.md")
    variant_dir = ROOT / variant["relative_dir"]
    html_out = variant_dir / variant["html"]
    pdf_out = variant_dir / variant["pdf"]

    if not source.exists():
        print(f"ERROR: CV source not found: {source}")
        raise SystemExit(1)

    print(f"Rendering {variant_id}...")
    html = render_html(source)
    html_out.write_text(html)
    print(f"  HTML: {html_out} ({len(html)} chars)")

    pdf = render_pdf(source, pdf_out)
    print(f"  PDF:  {pdf} ({pdf.stat().st_size / 1024:.0f} KB)")


def main(argv: list[str]) -> int:
    """CLI entry point."""
    registry = load_registry()
    if len(argv) > 1 and argv[1] == "--all":
        for variant_id in registry["variants"]:
            render_variant(variant_id, registry)
        print("Done.")
        return 0

    variant_id = argv[1] if len(argv) > 1 else registry["default_variant"]
    render_variant(variant_id, registry)
    print("Done.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
