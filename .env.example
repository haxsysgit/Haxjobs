# HaxJobs environment variables
# Copy to .env on the machine that runs the live pipeline.
# All are optional — defaults in haxjobs_config.py and api_server.py.

# ── Core paths ──
# HAXJOBS_HOME=/home/hax/haxjobs-private-dev
# HAXJOBS_DB=state/haxjobs.db

# ── User profile ──
# HAXJOBS_PROFILE=profile/arinze_profile.local.json

# ── LLM API keys (for direct evaluation) ──
# HAXJOBS_OPENAI_API_KEY=sk-...
# HAXJOBS_ANTHROPIC_API_KEY=sk-ant-...
# HAXJOBS_LLM_PROVIDER=openai          # openai | anthropic
# HAXJOBS_LLM_MODEL=gpt-5.5            # model to use for evaluation

# ── Onboarding ──
# HAXJOBS_ONBOARDING_ENABLED=true       # show onboarding wizard on first run

# ── API server ──
# HAXJOBS_API_HOST=127.0.0.1
# HAXJOBS_API_PORT=8241
# HAXJOBS_API_TOKEN=                   # set to enable token auth (otherwise open)

# ── Delivery ──
# HAXJOBS_TELEGRAM_BOT_TOKEN=
# HAXJOBS_TELEGRAM_CHAT_ID=
# HAXJOBS_EMAIL_SMTP_HOST=
# HAXJOBS_EMAIL_SMTP_PORT=587
# HAXJOBS_EMAIL_FROM=
# HAXJOBS_EMAIL_TO=
