# HaxJobs local environment example
# Copy to .env on the machine that runs the live pipeline.

# Email sending / intake
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_TO=

# Optional GitHub token for repo/API automation
GITHUB_TOKEN=

# LinkedIn browser automation is session-cookie based.
# Do not commit cookies or browser profile directories.
