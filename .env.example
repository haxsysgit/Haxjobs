# HaxJobs environment variables
# Copy to .env on the machine that runs the live pipeline.
# All are optional — defaults in haxjobs_config.py and api_server.py.

# ── Core paths ──
# HAXJOBS_HOME=/home/hax/haxjobs-private-dev
# HAXJOBS_DB=state/haxjobs.db

# ── User profile ──
# HAXJOBS_PROFILE=profile/arinze_profile.local.json
# HAXJOBS_CV_PROFILE=profile/cv_profile.typed.json

# ── API server ──
# HAXJOBS_API_HOST=127.0.0.1
# HAXJOBS_API_PORT=8800
# HAXJOBS_API_TOKEN=            # Set to enable token auth
# HAXJOBS_CORS_ORIGINS=         # Comma-separated, e.g. http://localhost:5173
# HAXJOBS_MAX_POST_BODY=1048576 # 1 MiB

# ── Email intake (IMAP) ──
# HAXJOBS_EMAIL_ADDRESS=archilleshaxsys@gmail.com
# HAXJOBS_EMAIL_IMAP_HOST=imap.gmail.com
# HAXJOBS_EMAIL_IMAP_PORT=993
# HAXJOBS_EMAIL_ALLOWED_SENDERS=elenasuluarinze@gmail.com,pentacker@gmail.com

# ── Telegram delivery ──
# HAXJOBS_TELEGRAM_CHAT_ID=-1003991695885
# HAXJOBS_TELEGRAM_THREAD_ID=18
